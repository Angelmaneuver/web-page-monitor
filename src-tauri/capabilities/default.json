{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "remote": {
    "urls": ["http://*", "https://*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "cli:default",
    "opener:default",
    "window-state:default"
  ]
}
